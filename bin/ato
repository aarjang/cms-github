#!/usr/bin/env bash
# ato — AI Token Optimizer for Claude Code
# Reduces token usage by 70-90% per session
# https://github.com/aarjang/ato

set -euo pipefail

VERSION="2.6.0"
CONTEXT_FILE="CONTEXT.md"
TASKS_FILE="TASKS.md"
DECISIONS_FILE="DECISIONS.md"
CLAUDE_FILE="CLAUDE.md"

GLOBAL_STATS="$HOME/.ato/stats.json"
LOCAL_STATS=".ato-stats.json"
TEMPLATES_DIR="${ATO_TEMPLATES:-$HOME/.ato/templates}"

TOKENS_PER_LINE=6
BASELINE_TOKENS=50000

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

info()    { echo -e "${CYAN}→${RESET} $*"; }
success() { echo -e "${GREEN}✓${RESET} $*"; }
warn()    { echo -e "${YELLOW}!${RESET} $*"; }
error()   { echo -e "${RED}✗${RESET} $*" >&2; }
header()  { echo -e "\n${BOLD}$*${RESET}"; }
dim()     { echo -e "${DIM}$*${RESET}"; }

# ─── JSON helpers (POSIX-compatible, no jq) ───────────────────────────
json_get() {
  local file="$1" key="$2"
  grep -o "\"$key\":[^,}]*" "$file" 2>/dev/null | \
    head -1 | sed 's/"[^"]*":[[:space:]]*//' | tr -d '"' | tr -d '[:space:]' || echo "0"
}

json_init_global() {
  mkdir -p "$(dirname "$GLOBAL_STATS")"
  if [[ ! -f "$GLOBAL_STATS" ]]; then
    cat > "$GLOBAL_STATS" << EOF
{
  "total_sessions": 0,
  "total_tokens_saved": 0,
  "total_tasks_done": 0,
  "first_use": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "last_use": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF
  fi
}

json_init_local() {
  local project="${1:-$(basename "$PWD")}"
  if [[ ! -f "$LOCAL_STATS" ]]; then
    cat > "$LOCAL_STATS" << EOF
{
  "project": "$project",
  "sessions": 0,
  "tokens_saved": 0,
  "tasks_done": 0,
  "created": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "last_session": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF
  fi
}

record_session() {
  local tokens_saved="${1:-0}"
  local project
  project="$(basename "$PWD")"

  if [[ -f "$LOCAL_STATS" ]]; then
    local prev_sessions prev_saved prev_tasks created
    prev_sessions=$(json_get "$LOCAL_STATS" "sessions")
    prev_saved=$(json_get "$LOCAL_STATS" "tokens_saved")
    prev_tasks=$(json_get "$LOCAL_STATS" "tasks_done")
    created=$(json_get "$LOCAL_STATS" "created")
    cat > "$LOCAL_STATS" << EOF
{
  "project": "$project",
  "sessions": $((prev_sessions + 1)),
  "tokens_saved": $((prev_saved + tokens_saved)),
  "tasks_done": $prev_tasks,
  "created": "$created",
  "last_session": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF
  fi

  json_init_global
  local g_sessions g_saved g_tasks g_first
  g_sessions=$(json_get "$GLOBAL_STATS" "total_sessions")
  g_saved=$(json_get "$GLOBAL_STATS" "total_tokens_saved")
  g_tasks=$(json_get "$GLOBAL_STATS" "total_tasks_done")
  g_first=$(json_get "$GLOBAL_STATS" "first_use")
  cat > "$GLOBAL_STATS" << EOF
{
  "total_sessions": $((g_sessions + 1)),
  "total_tokens_saved": $((g_saved + tokens_saved)),
  "total_tasks_done": $g_tasks,
  "first_use": "$g_first",
  "last_use": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF
}

record_task_done() {
  if [[ -f "$LOCAL_STATS" ]]; then
    local prev
    prev=$(json_get "$LOCAL_STATS" "tasks_done")
    awk -v new="$((prev + 1))" \
      '{ gsub(/"tasks_done":[[:space:]]*[0-9]+/, "\"tasks_done\": " new) } 1' \
      "$LOCAL_STATS" > "$LOCAL_STATS.tmp" && mv "$LOCAL_STATS.tmp" "$LOCAL_STATS"
  fi
  json_init_global
  local g_prev
  g_prev=$(json_get "$GLOBAL_STATS" "total_tasks_done")
  awk -v new="$((g_prev + 1))" \
    '{ gsub(/"total_tasks_done":[[:space:]]*[0-9]+/, "\"total_tasks_done\": " new) } 1' \
    "$GLOBAL_STATS" > "$GLOBAL_STATS.tmp" && mv "$GLOBAL_STATS.tmp" "$GLOBAL_STATS"
}

estimate_session_tokens() {
  local ctx_lines=0 task_lines=0
  [[ -f "$CONTEXT_FILE" ]] && ctx_lines=$(wc -l < "$CONTEXT_FILE")
  [[ -f "$TASKS_FILE" ]]   && task_lines=$(wc -l < "$TASKS_FILE")
  echo $(( (ctx_lines + task_lines) * TOKENS_PER_LINE + 500 ))
}

estimate_project_tokens() {
  local total session_est

  # Count lines in files with known code extensions
  local ext_lines
  ext_lines=$(find . \( -name "*.ts" -o -name "*.tsx" -o -name "*.js" \
         -o -name "*.py" -o -name "*.go" -o -name "*.rs" \
         -o -name "*.sh" -o -name "*.bash" \) \
    2>/dev/null | \
    grep -v "node_modules\|\.git\|dist\|build\|\.next\|__pycache__" | \
    xargs wc -l 2>/dev/null | tail -1 | awk '{print $1}')

  # Count lines in executable files without extensions (e.g. bin/ato)
  local exec_lines=0
  while IFS= read -r f; do
    head -1 "$f" 2>/dev/null | grep -q "^#!" && \
      exec_lines=$(( exec_lines + $(wc -l < "$f" 2>/dev/null) )) || true
  done < <(find . -type f ! -name "*.*" \
    -not -path "*/.git/*" -not -path "*/node_modules/*" \
    2>/dev/null)

  total=$(( ${ext_lines:-0} + exec_lines ))
  local estimated=$(( total * TOKENS_PER_LINE ))
  session_est=$(estimate_session_tokens)

  if [[ "$estimated" -le "$session_est" ]]; then
    echo "$BASELINE_TOKENS"
  else
    echo "$estimated"
  fi
}

fmt_tokens() {
  local n="$1"
  [[ $n -ge 1000 ]] && echo "$((n / 1000))k" || echo "$n"
}

# ─── Project scanner ──────────────────────────────────────────────────

_detect_stack() {
  local parts=()
  if [[ -f "package.json" ]]; then
    local fw
    fw=$(grep -oE '"(next|react|vue|svelte|express|fastify|nuxt|remix|astro|hono|nest)"' \
      package.json 2>/dev/null | tr -d '"' | sort -u | tr '\n' '/' | sed 's|/$||') || true
    if [[ -n "$fw" ]]; then parts+=("$fw"); else parts+=("Node.js"); fi
    if [[ -f "tsconfig.json" ]]; then parts+=("TypeScript"); fi
  fi
  if [[ -f "requirements.txt" || -f "pyproject.toml" || -f "setup.py" ]]; then parts+=("Python"); fi
  if [[ -f "go.mod" ]];                      then parts+=("Go");        fi
  if [[ -f "Cargo.toml" ]];                  then parts+=("Rust");      fi
  if [[ -f "pom.xml" || -f "build.gradle" ]]; then parts+=("Java");    fi
  if [[ -f "Gemfile" ]];                     then parts+=("Ruby");      fi
  if [[ -f "composer.json" ]];               then parts+=("PHP");       fi
  if [[ -f "docker-compose.yml" || -f "docker-compose.yaml" ]]; then parts+=("Docker"); fi
  local IFS=', '
  echo "${parts[*]:-[unknown — fill manually]}"
}

_detect_entry() {
  if [[ -f "package.json" ]]; then
    local main
    main=$(grep '"main"' package.json 2>/dev/null | \
      sed 's/.*"main":[[:space:]]*//' | tr -d '",' | sed 's/^[[:space:]]*//' | head -1) || true
    if [[ -n "$main" ]];       then echo "$main";         return; fi
    if [[ -f "src/index.ts" ]]; then echo "src/index.ts"; return; fi
    if [[ -f "src/index.js" ]]; then echo "src/index.js"; return; fi
    if [[ -f "src/app.ts" ]];   then echo "src/app.ts";   return; fi
    if [[ -f "index.ts" ]];     then echo "index.ts";     return; fi
    if [[ -f "index.js" ]];     then echo "index.js";     return; fi
  fi
  if [[ -f "main.go" ]];     then echo "main.go";       return; fi
  if [[ -f "cmd/main.go" ]]; then echo "cmd/main.go";   return; fi
  if [[ -f "main.py" ]];     then echo "main.py";       return; fi
  if [[ -f "app.py" ]];      then echo "app.py";        return; fi
  if [[ -f "src/main.py" ]]; then echo "src/main.py";   return; fi
  if [[ -f "src/main.rs" ]]; then echo "src/main.rs";   return; fi
  echo "[fill manually]"
}

_detect_run_cmd() {
  if [[ -f "package.json" ]]; then
    if grep -q '"dev"' package.json 2>/dev/null; then
      echo "npm run dev"; return
    fi
    echo "npm start"; return
  fi
  if [[ -f "Makefile" ]];    then echo "make";             return; fi
  if [[ -f "main.go" ]];     then echo "go run .";         return; fi
  if [[ -f "cmd/main.go" ]]; then echo "go run ./cmd/..."; return; fi
  if [[ -f "main.py" ]];     then echo "python main.py";   return; fi
  if [[ -f "app.py" ]];      then echo "python app.py";    return; fi
  if [[ -f "Cargo.toml" ]];  then echo "cargo run";        return; fi
  echo "[fill manually]"
}

_detect_description() {
  if [[ -f "package.json" ]]; then
    local desc
    # Extract only the value of "description" field (handles single-line JSON)
    desc=$(grep -oE '"description"[[:space:]]*:[[:space:]]*"[^"]*"' package.json 2>/dev/null | \
      sed 's/.*"description"[[:space:]]*:[[:space:]]*"//' | tr -d '"' | head -1)
    [[ -n "$desc" ]] && echo "$desc" && return
  fi
  if [[ -f "README.md" ]]; then
    local line
    while IFS= read -r line; do
      [[ "$line" =~ ^# ]] && continue
      [[ -z "${line// }" ]] && continue
      echo "$line"
      return
    done < README.md
  fi
  echo "[one sentence: what this project does]"
}

_detect_test_cmd() {
  if [[ -f "package.json" ]]; then
    grep -q '"test"'   package.json 2>/dev/null && echo "npm test"        && return
    grep -q '"vitest"' package.json 2>/dev/null && echo "npx vitest"      && return
  fi
  [[ -f "pytest.ini" || -f "conftest.py" ]] && echo "pytest"             && return
  [[ -f "go.mod" ]]                          && echo "go test ./..."      && return
  [[ -f "Cargo.toml" ]]                      && echo "cargo test"         && return
  [[ -f "Makefile" ]] && grep -q "^test:" Makefile 2>/dev/null && echo "make test" && return
  echo "[none detected]"
}

_detect_build_cmd() {
  if [[ -f "package.json" ]]; then
    grep -q '"build"' package.json 2>/dev/null && echo "npm run build" && return
  fi
  [[ -f "go.mod" ]]    && echo "go build ./..."       && return
  [[ -f "Cargo.toml" ]] && echo "cargo build --release" && return
  [[ -f "Makefile" ]] && grep -q "^build:" Makefile 2>/dev/null && echo "make build" && return
  echo "[none detected]"
}

_detect_lint_cmd() {
  if [[ -f "package.json" ]]; then
    grep -q '"lint"'  package.json 2>/dev/null && echo "npm run lint"  && return
    grep -q '"check"' package.json 2>/dev/null && echo "npm run check" && return
  fi
  [[ -f ".flake8" || -f "setup.cfg" ]]         && echo "flake8 ."         && return
  [[ -f ".golangci.yml" || -f "golangci-lint.yml" ]] && echo "golangci-lint run" && return
  echo "[none detected]"
}

_detect_key_deps() {
  if [[ -f "package.json" ]]; then
    grep -E '^\s+"[^"]+": "[^"]*"' package.json 2>/dev/null | \
      grep -v '"name"\|"version"\|"description"\|"main"\|"license"\|"author"\|"private"\|"type"\|"module"' | \
      sed 's/.*"\([^"]*\)":[[:space:]]*"\([^"]*\)".*/  \1: \2/' | \
      grep -v "^[[:space:]]*$" | head -14
    return
  fi
  if [[ -f "requirements.txt" ]]; then
    grep -v "^#\|^$" requirements.txt | head -12 | sed 's/^/  /'
    return
  fi
  if [[ -f "go.mod" ]]; then
    awk '/^require/,/^\)/' go.mod 2>/dev/null | grep -v "^require\|^\)\|^$" | \
      awk '{print "  " $1 " " $2}' | head -10
    return
  fi
  if [[ -f "Cargo.toml" ]]; then
    awk '/^\[dependencies\]/,/^\[/' Cargo.toml 2>/dev/null | \
      grep -v "^\[" | grep -v "^$" | head -10 | sed 's/^/  /'
    return
  fi
  echo "  [none detected]"
}

_detect_env_vars() {
  for f in .env.example .env.sample .env.template .env.test; do
    if [[ -f "$f" ]]; then
      grep -E '^[A-Z_]+=?' "$f" 2>/dev/null | \
        awk -F= '{print "  " $1 "=<value>"}' | head -15
      return
    fi
  done
  local found
  found=$(grep -rh "process\.env\." --include="*.ts" --include="*.js" \
    --exclude-dir=node_modules --exclude-dir=dist . 2>/dev/null | \
    grep -oE 'process\.env\.[A-Z_]+' | sed 's/process\.env\.//' | \
    sort -u | head -12 | awk '{print "  " $0 "=<value>"}')
  [[ -n "$found" ]] && echo "$found" && return
  echo "  [none detected — add .env.example to document these]"
}

_detect_conventions() {
  local parts=()
  [[ -f "tsconfig.json" ]] && \
    grep -q '"strict"[[:space:]]*:[[:space:]]*true' tsconfig.json 2>/dev/null && \
    parts+=("TypeScript strict")
  for f in .eslintrc .eslintrc.js .eslintrc.json .eslintrc.yml eslint.config.js eslint.config.mjs; do
    [[ -f "$f" ]] && parts+=("ESLint") && break
  done
  for f in .prettierrc .prettierrc.json .prettierrc.js prettier.config.js; do
    [[ -f "$f" ]] && parts+=("Prettier") && break
  done
  [[ -f ".editorconfig" ]] && parts+=("EditorConfig")
  for f in jest.config.js jest.config.ts jest.config.mjs; do
    [[ -f "$f" ]] && parts+=("Jest") && break
  done
  for f in vitest.config.ts vitest.config.js; do
    [[ -f "$f" ]] && parts+=("Vitest") && break
  done
  [[ -d ".github/workflows" ]] && parts+=("GitHub Actions")
  [[ -f "docker-compose.yml" || -f "docker-compose.yaml" ]] && parts+=("Docker Compose")
  [[ ${#parts[@]} -eq 0 ]] && echo "  [none detected]" && return
  local IFS=', '
  echo "  ${parts[*]}"
}

_detect_god_files() {
  local result
  result=$(git log --since="90 days ago" --name-only --format="" 2>/dev/null | \
    grep -v "^$\|\.lock$\|CONTEXT\.md\|CLAUDE\.md\|\.ato-stats\|\.cms-stats\|\.gitignore" | \
    sort | uniq -c | sort -rn | head -7 | \
    awk '{printf "  %-45s (%d changes)\n", $2, $1}')
  [[ -n "$result" ]] && echo "$result" || echo "  [no git history yet]"
}

_make_bar() {
  local filled="$1" total="$2" bar=""
  local i
  for ((i=0; i<total; i++)); do
    if ((i < filled)); then bar+="█"; else bar+="░"; fi
  done
  echo "$bar"
}

_generate_tree() {
  # Single find sorted naturally so dirs appear before their children
  find . -mindepth 1 -maxdepth 3 \
    -not -path "*/.git"            -not -path "*/.git/*" \
    -not -path "*/node_modules"    -not -path "*/node_modules/*" \
    -not -path "*/dist"            -not -path "*/dist/*" \
    -not -path "*/build"           -not -path "*/build/*" \
    -not -path "*/__pycache__"     -not -path "*/__pycache__/*" \
    -not -path "*/.next"           -not -path "*/.next/*" \
    -not -path "*/vendor"          -not -path "*/vendor/*" \
    -not -path "*/.cache"          -not -path "*/.cache/*" \
    -not -path "*/.terraform"      -not -path "*/.terraform/*" \
    -not -name "*.lock" -not -name ".DS_Store" \
    -not -name "*.pyc"  -not -name "*.class" \
    2>/dev/null | sort | sed 's|^\./||' | \
    awk -F'/' '{
      depth = NF - 1
      name = $NF
      prefix = ""
      for (i = 0; i < depth; i++) prefix = prefix "  "
      if (depth == 0) print name
      else            print prefix "└─ " name
    }' | head -60
}

_auto_fill_context() {
  local project="$1"
  local stack entry run_cmd test_cmd build_cmd lint_cmd description branch tree
  local key_deps env_vars conventions git_log god_files

  info "Scanning project..."
  description=$(_detect_description)
  stack=$(_detect_stack)
  entry=$(_detect_entry)
  run_cmd=$(_detect_run_cmd)
  test_cmd=$(_detect_test_cmd)
  build_cmd=$(_detect_build_cmd)
  lint_cmd=$(_detect_lint_cmd)
  key_deps=$(_detect_key_deps)
  env_vars=$(_detect_env_vars)
  conventions=$(_detect_conventions)
  god_files=$(_detect_god_files)
  branch=$(git branch --show-current 2>/dev/null || echo "main")
  tree=$(_generate_tree)
  git_log=$(git log --oneline -5 --format="  %h %s (%ar)" 2>/dev/null || echo "  [no git history yet]")

  cat > "$CONTEXT_FILE" << EOF
# PROJECT CONTEXT — $project
<!-- Generated: $(date +%Y-%m-%d) by ato v${VERSION} -->
<!-- Updated automatically by stop-hook → ato sync after each session -->
<!-- Claude: read this FULLY before responding. Do NOT scan the full codebase. -->

## Identity
$description

Stack:   $stack
Entry:   $entry
Branch:  $branch

## Commands
\`\`\`bash
run:   $run_cmd
test:  $test_cmd
build: $build_cmd
lint:  $lint_cmd
\`\`\`

## Structure
\`\`\`
$project/
$tree
\`\`\`

## Key dependencies
$key_deps

## Environment variables
$env_vars

## Conventions
$conventions

## Hot files (most-changed — read these first)
$god_files

## Recent git history
$git_log

## Anti-patterns
<!-- Fill in as you discover footguns in this codebase — Claude will respect them -->
- [none yet — add constraints here after your first session]

## Session notes
<!-- Auto-updated by ato sync -->
Last session: [none yet]
Changed:      [none yet]
EOF

  local final_lines
  final_lines=$(wc -l < "$CONTEXT_FILE")
  success "CONTEXT.md generated ($final_lines lines — $(( final_lines * TOKENS_PER_LINE )) est. tokens)"
}

# ─── Hook setup ───────────────────────────────────────────────────────

_setup_hook() {
  # Only in git repos (real projects)
  [[ ! -d ".git" ]] && return

  local settings_dir=".claude"
  local settings_file="$settings_dir/settings.json"

  mkdir -p "$settings_dir"

  if [[ ! -f "$settings_file" ]]; then
    cat > "$settings_file" << 'HOOKEOF'
{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "ato sync"
          }
        ]
      }
    ]
  }
}
HOOKEOF
    success "Claude Code stop-hook installed → ato sync runs automatically after each session"
  elif ! grep -q "ato sync" "$settings_file" 2>/dev/null; then
    warn "Existing .claude/settings.json found. Add this manually to enable auto-sync:"
    dim '  "Stop": [{"matcher":"","hooks":[{"type":"command","command":"ato sync"}]}]'
  fi
}

# ─── Task helpers ─────────────────────────────────────────────────────

_next_task_num() {
  local max=0 num
  while IFS= read -r line; do
    num=$(echo "$line" | awk -F'|' '{gsub(/[[:space:]]/, "", $2); print $2}')
    if [[ "$num" =~ ^[0-9]+$ ]] && [[ $num -gt $max ]]; then
      max=$num
    fi
  done < <(grep "^| [0-9]" "$TASKS_FILE" 2>/dev/null || true)
  echo $((max + 1))
}

_get_task_row()  { grep "^| $1 |" "$TASKS_FILE" 2>/dev/null | head -1; }

_get_task_name() {
  _get_task_row "$1" | awk -F'|' '{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $3); print $3}'
}

_pick_task() {
  local rows=()
  while IFS= read -r line; do
    rows+=("$line")
  done < <(grep "^| [0-9]" "$TASKS_FILE" 2>/dev/null)

  if [[ ${#rows[@]} -eq 0 ]]; then
    error "No tasks found."
    info "Add one: ato add \"describe your task\""
    exit 1
  fi

  echo ""
  echo -e "${BOLD}  Pick a task:${RESET}"
  echo ""
  local num desc status
  for row in "${rows[@]}"; do
    num=$(echo "$row"    | awk -F'|' '{gsub(/[[:space:]]/, "", $2); print $2}')
    desc=$(echo "$row"   | awk -F'|' '{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $3); print $3}')
    status=$(echo "$row" | awk -F'|' '{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $4); print $4}')
    printf "  ${CYAN}%2s${RESET}  %-44s ${DIM}[%s]${RESET}\n" "$num" "$desc" "$status"
  done
  echo ""
  printf "  ${BOLD}>${RESET} "
  local choice
  read -r choice </dev/tty 2>/dev/null || choice=""
  echo ""
  [[ -z "$choice" ]] && { error "No task selected."; exit 1; }
  cmd_focus "$choice"
}

_topic_focus() {
  local topic="$1"
  [[ ! -f "$CONTEXT_FILE" ]] && { error "CONTEXT.md not found — run: ato init"; exit 1; }

  # Files with topic in their path
  local path_files commit_files topic_files
  path_files=$(git ls-files 2>/dev/null | grep -i "$topic" | head -5 || true)

  # Files from commits mentioning the topic
  commit_files=$(git log --all --oneline --grep="$topic" -i --name-only --format="" 2>/dev/null | \
    grep -v "^$\|CONTEXT\.md\|CLAUDE\.md\|\.lock$\|\.ato-stats" | \
    sort | uniq -c | sort -rn | awk '{print $2}' | head -8 || true)

  topic_files=$(printf "%s\n%s" "$path_files" "$commit_files" | \
    grep -v "^$" | awk '!seen[$0]++' | head -8 || true)

  if [[ -z "$topic_files" ]]; then
    warn "No files found related to: $topic"
    info "Try: ato focus (auto-detect) or ato focus <task-id>"
    return
  fi

  local focused=".ato_focus_auto.md"
  {
    echo "# Claude Code — Topic Focus: $topic"
    echo "# $(date +%Y-%m-%d\ %H:%M)"
    echo ""
    echo "## Context (read this first):"
    cat "$CONTEXT_FILE"
    echo ""
    echo "---"
    echo "## Topic: $topic"
    echo ""
    echo "Focus ONLY on these files (related to: $topic):"
    echo ""
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      if [[ -f "$f" ]]; then
        local lines
        lines=$(wc -l < "$f" 2>/dev/null | tr -d ' ')
        echo "  - \`$f\`  ($lines lines)"
      else
        echo "  - \`$f\`"
      fi
    done <<< "$topic_files"
    echo ""
    echo "### Recent commits related to $topic:"
    git log --oneline --grep="$topic" -i 2>/dev/null | head -5 | awk '{print "  " $0}' || echo "  [none]"
    echo ""
    echo "---"
    echo "## Session rules:"
    echo "1. Only read files listed above — do NOT explore the rest of the codebase"
    echo "2. Ask before touching any file not in scope"
    echo "3. Keep changes minimal and targeted"
    echo "4. When done: report DONE + one-line summary"
  } > "$focused"

  record_session 0

  success "Focused on topic: $topic"
  echo ""
  info "Files in scope:"
  while IFS= read -r f; do
    [[ -n "$f" ]] && dim "    $f"
  done <<< "$topic_files"
  echo ""
  info "Paste into Claude Code:"
  echo ""
  echo -e "${BOLD}    Read $focused and follow the session rules inside it.${RESET}"
  echo ""
}

_auto_focus() {
  local budget_k="${1:-0}"
  [[ ! -f "$CONTEXT_FILE" ]] && { error "CONTEXT.md not found — run: ato init"; exit 1; }

  local branch modified_files recent_files all_focus_files focus_area focused

  branch=$(git branch --show-current 2>/dev/null || echo "main")

  # Signal 1: currently modified/staged files (strongest signal)
  modified_files=$(git status --short 2>/dev/null | \
    awk '{print $NF}' | \
    grep -v "^$\|CONTEXT\.md\|CLAUDE\.md\|\.ato-stats\|\.cms-stats" | head -6)

  # Signal 2: files touched in last 7 days (recent context)
  recent_files=$(git log --since="7 days ago" --name-only --format="" 2>/dev/null | \
    grep -v "^$\|CONTEXT\.md\|CLAUDE\.md\|\.lock$\|\.ato-stats\|\.cms-stats" | \
    sort | uniq -c | sort -rn | awk '{print $2}' | head -8)

  # Merge deduped: modified first, then recent
  all_focus_files=$(printf "%s\n%s" "$modified_files" "$recent_files" | \
    grep -v "^$" | awk '!seen[$0]++' | head -8 || true)

  if [[ -z "$all_focus_files" ]]; then
    warn "No recent changes detected — nothing to focus on."
    info "Make some changes or run: ato focus <task-id>"
    return
  fi

  # If budget set, trim file list so total lines fit within budget
  if [[ "$budget_k" -gt 0 ]]; then
    local budget_tokens=$(( budget_k * 1000 ))
    local ctx_overhead=$(( $(wc -l < "$CONTEXT_FILE") * TOKENS_PER_LINE + 33000 ))
    local remaining=$(( budget_tokens - ctx_overhead ))
    local trimmed="" running=0
    while IFS= read -r f; do
      [[ -z "$f" || ! -f "$f" ]] && continue
      local flines
      flines=$(wc -l < "$f" 2>/dev/null || echo 0)
      local ftok=$(( flines * TOKENS_PER_LINE ))
      if [[ $(( running + ftok )) -le $remaining ]]; then
        trimmed="${trimmed}${f}"$'\n'
        running=$(( running + ftok ))
      fi
    done <<< "$all_focus_files"
    all_focus_files=$(echo "$trimmed" | grep -v "^$" || true)
    info "Budget: ${budget_k}k tokens — scope trimmed to fit (~$(fmt_tokens $running) for files)"
  fi

  # Derive focus area name from branch (strip common prefixes)
  focus_area=$(echo "$branch" | \
    sed 's|^feature/||; s|^feat/||; s|^fix/||; s|^hotfix/||; s|^chore/||; s|^refactor/||' | \
    sed 's/-/ /g; s/_/ /g')
  { [[ "$focus_area" == "main" ]] || [[ "$focus_area" == "master" ]] || \
    [[ "$focus_area" == "develop" ]]; } && focus_area="current changes"

  focused=".ato_focus_auto.md"

  {
    echo "# Claude Code — Auto-Focus Session"
    echo "# Area: $focus_area  |  branch: $branch  |  $(date +%Y-%m-%d\ %H:%M)"
    echo ""
    echo "## Context (read this first):"
    cat "$CONTEXT_FILE"
    echo ""
    echo "---"
    echo "## Auto-detected work area: $focus_area"
    echo ""
    echo "Focus ONLY on these files (derived from git signals):"
    echo ""
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      if [[ -f "$f" ]]; then
        local lines
        lines=$(wc -l < "$f" 2>/dev/null | tr -d ' ')
        echo "  - \`$f\`  ($lines lines)"
      else
        echo "  - \`$f\`"
      fi
    done <<< "$all_focus_files"
    echo ""
    echo "### Recent commits touching these files:"
    # shellcheck disable=SC2086
    git log --since="14 days ago" --oneline -- $all_focus_files 2>/dev/null | \
      head -5 | awk '{print "  " $0}' || echo "  [none]"
    echo ""
    echo "---"
    echo "## Session rules:"
    echo "1. Only read files listed above — do NOT explore the rest of the codebase"
    echo "2. Ask before touching any file not in scope"
    echo "3. Keep changes minimal and targeted"
    echo "4. When done: report DONE + one-line summary"
  } > "$focused"

  record_session 0

  success "Auto-focused: $focus_area"
  echo ""
  info "Files in scope:"
  while IFS= read -r f; do
    [[ -n "$f" ]] && dim "    $f"
  done <<< "$all_focus_files"
  echo ""

  # Startup token breakdown
  local ctx_t cl_t focus_t startup_t avail
  ctx_t=$(( $(wc -l < "$CONTEXT_FILE" 2>/dev/null || echo 0) * TOKENS_PER_LINE ))
  cl_t=$(( $(wc -l < "$CLAUDE_FILE" 2>/dev/null || echo 0) * TOKENS_PER_LINE ))
  focus_t=$(( $(wc -l < "$focused" 2>/dev/null || echo 0) * TOKENS_PER_LINE ))
  startup_t=$(( ctx_t + cl_t + focus_t ))
  avail=$(( 200000 - 33000 - startup_t ))
  echo -e "  ${DIM}Startup cost: CONTEXT ~$(fmt_tokens $ctx_t) + CLAUDE.md ~$(fmt_tokens $cl_t) + focus file ~$(fmt_tokens $focus_t) = ~$(fmt_tokens $startup_t) tokens${RESET}"
  echo -e "  ${DIM}Available for work: ~$(fmt_tokens $avail) / ~200k tokens${RESET}"
  echo ""

  info "Paste into Claude Code:"
  echo ""
  echo -e "${BOLD}    Read $focused and follow the session rules inside it.${RESET}"
  echo ""
}

# ─── Commands ─────────────────────────────────────────────────────────

cmd_init() {
  local project="${1:-$(basename "$PWD")}"
  header "Initializing ATO v${VERSION} — $project"

  # CONTEXT.md
  if [[ -f "$CONTEXT_FILE" ]]; then
    warn "$CONTEXT_FILE already exists."
    printf "  ${BOLD}Regenerate it? This will overwrite your current context. [y/N]${RESET} "
    local answer
    read -r answer </dev/tty 2>/dev/null || answer="n"
    echo ""
    if [[ "$answer" =~ ^[Yy]$ ]]; then
      cp "$CONTEXT_FILE" "${CONTEXT_FILE}.bak"
      info "Backup saved → ${CONTEXT_FILE}.bak"
      _auto_fill_context "$project"
    else
      info "Keeping existing $CONTEXT_FILE"
    fi
  else
    _auto_fill_context "$project"
  fi

  # CLAUDE.md
  if [[ -f "$CLAUDE_FILE" ]]; then
    warn "$CLAUDE_FILE already exists — skipping"
  else
    local tmpl="$TEMPLATES_DIR/$CLAUDE_FILE"
    if [[ -f "$tmpl" ]]; then
      cp "$tmpl" "$CLAUDE_FILE"
      sed -i.bak "s/\[PROJECT_NAME\]/$project/g" "$CLAUDE_FILE" && rm -f "$CLAUDE_FILE.bak"
    else
      _create_minimal "$CLAUDE_FILE" "$project"
    fi
    success "Created $CLAUDE_FILE"
  fi

  json_init_local "$project"
  json_init_global
  success "Stats tracking initialized"

  if [[ -f ".gitignore" ]] && ! grep -q "ato-stats" .gitignore 2>/dev/null; then
    printf '\n# ATO stats\n.ato-stats.json\n' >> .gitignore
  fi

  _setup_hook

  echo ""
  echo -e "  ${GREEN}${BOLD}✓ Done!${RESET}"
  echo ""
  echo -e "  ${BOLD}Next steps:${RESET}"
  dim "  1. Review CONTEXT.md — fill in Anti-patterns + any missing info"
  dim "  2. Run: claude"
  dim "     Claude reads CONTEXT.md automatically and asks what to work on"
  dim "  3. After each session, CONTEXT.md is updated automatically"
  echo ""
}

_file_checksum() { cksum "$1" 2>/dev/null | awk '{print $1}'; }

cmd_sync() {
  [[ ! -f "$CONTEXT_FILE" ]] && { error "CONTEXT.md not found — run: ato init"; exit 1; }

  local checksum_before
  checksum_before=$(_file_checksum "$CONTEXT_FILE")

  local branch today changed
  branch=$(git branch --show-current 2>/dev/null || echo "main")
  today=$(date +%Y-%m-%d)

  changed=$(git status --short 2>/dev/null | awk '{print $NF}' | sort -u | \
    grep -v "^$" | head -8 | tr '\n' ' ' | sed 's/[[:space:]]*$//' || true)

  local git_log_inline
  git_log_inline=$(git log --oneline -5 --format="  %h %s (%ar)" 2>/dev/null || echo "  [no history]")

  awk \
    -v branch="$branch" \
    -v today="$today" \
    -v changed="${changed:-nothing modified}" \
    '
    /^Branch: /           { print "Branch:  " branch; next }
    /^Last session: /     { print "Last session: " today; next }
    /^Changed: /          { print "Changed:      " changed; next }
    /^Current focus: /    { print "Current focus: `" changed "`"; next }
    /^Recently changed: / { print "Recently changed: " changed; next }
    { print }
    ' "$CONTEXT_FILE" > "$CONTEXT_FILE.tmp" && mv "$CONTEXT_FILE.tmp" "$CONTEXT_FILE"

  # Update git history block in-place (use temp file to handle multi-line content)
  local tmp_log
  tmp_log=$(mktemp)
  echo "$git_log_inline" > "$tmp_log"
  awk \
    -v logfile="$tmp_log" \
    '
    /^## Recent git history/ {
      print
      while ((getline line < logfile) > 0) print line
      close(logfile)
      skip=1; next
    }
    skip && /^## /           { skip=0 }
    !skip                    { print }
    ' "$CONTEXT_FILE" > "$CONTEXT_FILE.tmp" && mv "$CONTEXT_FILE.tmp" "$CONTEXT_FILE"
  rm -f "$tmp_log"

  local session_tokens full_tokens saved
  session_tokens=$(estimate_session_tokens)
  full_tokens=$(estimate_project_tokens)
  saved=$(( full_tokens - session_tokens ))
  [[ $saved -lt 0 ]] && saved=0
  record_session "$saved"

  local checksum_after
  checksum_after=$(_file_checksum "$CONTEXT_FILE")

  if [[ "$checksum_before" == "$checksum_after" ]]; then
    info "CONTEXT.md unchanged — nothing to sync"
  else
    success "CONTEXT.md synced — branch: $branch | $(date +%H:%M)"
    [[ -n "$changed" ]] && info "Files: $changed"
  fi
  info "Saved ~$(fmt_tokens $saved) tokens this session"

  # Compaction warning: if last sync was not today, compaction may have occurred
  local last_s today
  last_s=$(json_get "$LOCAL_STATS" "last_session" 2>/dev/null | cut -c1-10 || echo "")
  today=$(date +%Y-%m-%d)
  if [[ -n "$last_s" && "$last_s" != "$today" ]]; then
    warn "Last session was $last_s — Claude may have compacted this session"
    dim "  Key decisions from today may be lost. Consider: ato note \"what was decided\""
  fi
}

cmd_add() {
  local desc="${1:-}"
  [[ -z "$desc" ]] && { error "Usage: ato add \"task description\""; exit 1; }
  [[ ! -f "$TASKS_FILE" ]] && { error "TASKS.md not found — run: ato init"; exit 1; }

  local next
  next=$(_next_task_num)

  # Insert row after last task row (or after header separator)
  local last_row
  last_row=$(grep -n "^| [0-9]" "$TASKS_FILE" 2>/dev/null | tail -1 | cut -d: -f1) || true
  if [[ -z "$last_row" ]]; then
    last_row=$(grep -n "^|[-|]" "$TASKS_FILE" 2>/dev/null | head -1 | cut -d: -f1) || true
  fi

  if [[ -n "$last_row" ]]; then
    awk -v row="$last_row" -v num="$next" -v desc="$desc" '
      NR == row { print; printf "| %s | %s | up-next |\n", num, desc; next }
      { print }
    ' "$TASKS_FILE" > "$TASKS_FILE.tmp" && mv "$TASKS_FILE.tmp" "$TASKS_FILE"
  else
    echo "| $next | $desc | up-next |" >> "$TASKS_FILE"
  fi

  # Append detail block
  cat >> "$TASKS_FILE" << EOF

### ${next}: ${desc}
**Goal:** [what done looks like]
**Scope:**
- \`[file]\` — [what to change]

**Done when:**
- [ ] [acceptance criterion]

**Test:** \`[test command]\`
EOF

  success "Task $next added: \"$desc\""
  info "Run: ato focus $next"
}

cmd_focus() {
  # Parse --budget flag anywhere in args
  local budget_k=0 args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --budget)
        shift
        # accept "40k", "40K", or "40000"
        budget_k=$(echo "${1:-0}" | sed 's/[kK]$//')
        [[ "$budget_k" -gt 0 ]] 2>/dev/null || budget_k=0
        ;;
      --budget=*)
        local bval="${1#--budget=}"
        budget_k=$(echo "$bval" | sed 's/[kK]$//')
        [[ "$budget_k" -gt 0 ]] 2>/dev/null || budget_k=0
        ;;
      *) args+=("$1") ;;
    esac
    shift
  done
  set -- "${args[@]+"${args[@]}"}"

  local task_id="${1:-}"

  if [[ -z "$task_id" ]]; then
    _auto_focus "$budget_k"
    return
  fi

  # numeric → task by ID; non-numeric → check TASKS.md, else topic focus
  if [[ ! "$task_id" =~ ^[0-9]+$ ]]; then
    local in_tasks
    in_tasks=$(grep -c "^### ${task_id}:" "$TASKS_FILE" 2>/dev/null || true)
    if [[ "${in_tasks:-0}" -eq 0 ]]; then
      _topic_focus "$task_id"
      return
    fi
  fi

  local task_label="$task_id"
  if [[ "$task_id" =~ ^[0-9]+$ ]]; then
    local row
    row=$(_get_task_row "$task_id")
    if [[ -z "$row" ]]; then
      error "Task $task_id not found."
      info "See tasks: ato focus   |   Add: ato add \"description\""
      exit 1
    fi
    task_label=$(_get_task_name "$task_id")
  fi

  local focused=".cms_focus_${task_id}.md"
  local session_tokens full_tokens saved
  session_tokens=$(estimate_session_tokens)
  full_tokens=$(estimate_project_tokens)
  saved=$(( full_tokens - session_tokens ))
  [[ $saved -lt 0 ]] && saved=0

  local task_detail
  if [[ "$task_id" =~ ^[0-9]+$ ]]; then
    task_detail=$(grep -A 30 "^### ${task_id}:" "$TASKS_FILE" 2>/dev/null | \
      awk '/^### [0-9]/ && !/^### '"$task_id"':/ { exit } { print }')
  else
    task_detail=$(grep -A 30 "### ${task_id}:" "$TASKS_FILE" 2>/dev/null | \
      awk '/^### [A-Z]/ && !/^### '"$task_id"':/ { exit } { print }')
  fi

  if [[ -z "$task_detail" ]]; then
    task_detail="Task: $task_label

Fill in TASKS.md under:
### ${task_id}: $task_label
**Goal:** ...
**Scope:** ..."
  fi

  cat > "$focused" << EOF
# Claude Code — Focused Session (Task ${task_id}: ${task_label})
# Token saving: ~$(fmt_tokens $saved) vs reading the full codebase

## Context (read this first):
$(cat "$CONTEXT_FILE" 2>/dev/null || echo "⚠ CONTEXT.md not found — run: ato init")

---
## Your task:
$task_detail

---
## Session rules:
1. Only read files listed in Scope above
2. Do NOT explore the codebase
3. Ask before reading anything not in Scope
4. When done: update checkboxes in TASKS.md
5. Report: DONE / BLOCKED + one line
EOF

  record_session "$saved"

  success "Task $task_id: \"$task_label\""
  success "Estimated saving: ~$(fmt_tokens $saved) tokens"
  echo ""
  info "Paste into Claude Code:"
  echo ""
  echo -e "${BOLD}    Read $focused and follow the session rules inside it.${RESET}"
  echo ""
}

cmd_done() {
  local task_id="${1:-}"
  [[ -z "$task_id" ]] && { error "Usage: ato done <task-number>"; exit 1; }

  local archive="ARCHIVE.md"
  local today
  today=$(date +%Y-%m-%d)

  if [[ "$task_id" =~ ^[0-9]+$ ]]; then
    if grep -q "^### ${task_id}:" "$TASKS_FILE" 2>/dev/null; then
      local task_name
      task_name=$(grep "^### ${task_id}:" "$TASKS_FILE" | head -1 | \
        awk -F': ' 'NF>1{$1=""; gsub(/^ /, ""); print}')
      {
        echo "### $task_id — ${task_name} — DONE $today"
        grep -A 25 "^### ${task_id}:" "$TASKS_FILE" | tail -n +2 | head -20
        echo ""
      } >> "$archive"
      awk -v id="$task_id" '
        BEGIN { pat = "^[|] " id " [|]" }
        $0 ~ pat { gsub(/up-next|in-progress|blocked/, "done") }
        { print }
      ' "$TASKS_FILE" > "$TASKS_FILE.tmp" && mv "$TASKS_FILE.tmp" "$TASKS_FILE"
      record_task_done
      cmd_sync 2>/dev/null || true
      success "Task $task_id done: \"$task_name\""
      info "Keep going: ato add \"next task\""
    else
      warn "No detail block found for task $task_id"
      warn "Add to TASKS.md: ### ${task_id}: task name"
    fi
  else
    if grep -q "### $task_id:" "$TASKS_FILE" 2>/dev/null; then
      {
        echo "### $task_id — DONE $today"
        grep -A 25 "### $task_id:" "$TASKS_FILE" | tail -n +2 | head -20
        echo ""
      } >> "$archive"
      record_task_done
      cmd_sync 2>/dev/null || true
      success "Task $task_id archived"
    else
      warn "Task $task_id not found in TASKS.md"
    fi
  fi
}

cmd_stats() {
  local scope="${1:-both}"

  header "ATO Token Savings"

  if [[ "$scope" != "global" ]] && [[ -f "$LOCAL_STATS" ]]; then
    local project sessions tokens_saved tasks_done last
    project=$(json_get "$LOCAL_STATS" "project")
    sessions=$(json_get "$LOCAL_STATS" "sessions")
    tokens_saved=$(json_get "$LOCAL_STATS" "tokens_saved")
    tasks_done=$(json_get "$LOCAL_STATS" "tasks_done")
    last=$(json_get "$LOCAL_STATS" "last_session" | cut -c1-10)

    echo ""
    echo -e "${BOLD}  📁 Project: $project${RESET}"
    echo -e "  ┌─────────────────────────────────────┐"
    printf  "  │  Sessions run       %16s  │\n" "$sessions"
    printf  "  │  Tokens saved       %16s  │\n" "~$(fmt_tokens $tokens_saved)"
    printf  "  │  Tasks completed    %16s  │\n" "$tasks_done"
    printf  "  │  Last session       %16s  │\n" "$last"
    echo -e "  └─────────────────────────────────────┘"

    if [[ $sessions -gt 0 ]] && [[ $tokens_saved -gt 0 ]]; then
      local per_session=$(( tokens_saved / sessions ))
      echo -e "  ${DIM}avg $(fmt_tokens $per_session) tokens saved per session${RESET}"
    fi
    if [[ $tokens_saved -gt 0 ]]; then
      local cost_usd
      cost_usd=$(echo "scale=2; $tokens_saved * 3 / 1000000" | bc 2>/dev/null || echo "?")
      echo -e "  ${DIM}≈ \$$cost_usd saved in API costs (@ \$3/MTok)${RESET}"
    fi
  fi

  if [[ "$scope" != "local" ]]; then
    json_init_global
    local g_sessions g_saved g_tasks g_first
    g_sessions=$(json_get "$GLOBAL_STATS" "total_sessions")
    g_saved=$(json_get "$GLOBAL_STATS" "total_tokens_saved")
    g_tasks=$(json_get "$GLOBAL_STATS" "total_tasks_done")
    g_first=$(json_get "$GLOBAL_STATS" "first_use" | cut -c1-10)

    echo ""
    echo -e "${BOLD}  🌍 All projects (since $g_first)${RESET}"
    echo -e "  ┌─────────────────────────────────────┐"
    printf  "  │  Total sessions     %16s  │\n" "$g_sessions"
    printf  "  │  Total tokens saved %16s  │\n" "~$(fmt_tokens $g_saved)"
    printf  "  │  Total tasks done   %16s  │\n" "$g_tasks"
    echo -e "  └─────────────────────────────────────┘"

    if [[ $g_saved -gt 0 ]]; then
      local g_cost
      g_cost=$(echo "scale=2; $g_saved * 3 / 1000000" | bc 2>/dev/null || echo "?")
      echo -e "  ${DIM}≈ \$$g_cost total API cost saved${RESET}"
    fi
  fi
  echo ""
}

cmd_status() {
  local project
  project="$(basename "$PWD")"
  local W=50   # box width (inner)

  echo ""
  # ── Header ──────────────────────────────────────────────────
  local title="  ATO v${VERSION} — ${project}"
  printf "${BOLD}╔%${W}s╗${RESET}\n" | tr ' ' '═'
  printf "${BOLD}║${RESET}%-${W}s${BOLD}║${RESET}\n" "$title"
  printf "${BOLD}╚%${W}s╝${RESET}\n" | tr ' ' '═'
  echo ""

  # ── Files ───────────────────────────────────────────────────
  echo -e "  ${BOLD}Files${RESET}"
  printf "  %s\n" "$(printf '─%.0s' {1..46})"

  if [[ -f "$CONTEXT_FILE" ]]; then
    local lines tokens health_tag
    lines=$(wc -l < "$CONTEXT_FILE")
    tokens=$(( lines * TOKENS_PER_LINE ))
    if [[ $lines -gt 200 ]]; then
      health_tag="${YELLOW}⚠ too large — run: ato trim${RESET}"
    else
      health_tag="${GREEN}lean ✓${RESET}"
    fi
    printf "  ${GREEN}✓${RESET}  %-18s %3d lines  (~%-5s tokens)  " "CONTEXT.md" "$lines" "$(fmt_tokens $tokens)"
    echo -e "$health_tag"
  else
    echo -e "  ${RED}✗${RESET}  CONTEXT.md          ${RED}missing — run: ato init${RESET}"
  fi

  if [[ -f "$CLAUDE_FILE" ]]; then
    printf "  ${GREEN}✓${RESET}  %-18s %s\n" "CLAUDE.md" "present"
  else
    printf "  ${YELLOW}!${RESET}  %-18s %s\n" "CLAUDE.md" "missing"
  fi

  if [[ -f ".claude/settings.json" ]] && grep -q "ato sync" .claude/settings.json 2>/dev/null; then
    printf "  ${GREEN}✓${RESET}  %-18s %s\n" "Stop-hook" "installed  (auto-sync active)"
  else
    printf "  ${YELLOW}!${RESET}  %-18s %s\n" "Stop-hook" "not set — run: ato init"
  fi
  echo ""

  # ── Token budget ────────────────────────────────────────────
  echo -e "  ${BOLD}Token budget${RESET}"
  printf "  %s\n" "$(printf '─%.0s' {1..46})"

  local session_tokens full_tokens pct=0
  session_tokens=$(estimate_session_tokens)
  full_tokens=$(estimate_project_tokens)
  [[ $full_tokens -gt 0 ]] && pct=$(( (full_tokens - session_tokens) * 100 / full_tokens ))

  local bar_len=22
  local filled=$(( bar_len * session_tokens / (full_tokens > 0 ? full_tokens : 1) ))
  [[ $filled -gt $bar_len ]] && filled=$bar_len
  local bar_full bar_ato
  bar_full=$(_make_bar $bar_len $bar_len)
  bar_ato=$(_make_bar $filled $bar_len)

  printf "  %-14s  %s  ~%s\n" "Without ato"  "$bar_full" "$(fmt_tokens $full_tokens) tokens"
  printf "  %-14s  %s  ~%s\n" "With ato"     "$bar_ato"  "$(fmt_tokens $session_tokens) tokens"
  echo -e "  ${GREEN}Saving ~${pct}% per session${RESET}"
  echo ""

  # ── Git ─────────────────────────────────────────────────────
  echo -e "  ${BOLD}Git${RESET}"
  printf "  %s\n" "$(printf '─%.0s' {1..46})"

  local git_branch git_state git_last
  git_branch=$(git branch --show-current 2>/dev/null || echo "n/a")

  local mod unt
  mod=$(git status --short 2>/dev/null | grep -c "^[MADRCU ]" || true); mod=${mod:-0}
  unt=$(git status --short 2>/dev/null | grep -c '^??' || true); unt=${unt:-0}
  if [[ $mod -eq 0 && $unt -eq 0 ]]; then
    git_state="${GREEN}clean${RESET}"
  else
    git_state="${mod} modified, ${unt} untracked"
  fi
  git_last=$(git log --oneline -1 --format='"%s" (%ar)' 2>/dev/null || echo "n/a")

  printf "  %-14s  %s\n"     "Branch"      "$git_branch"
  printf "  %-14s  "         "Status"
  echo -e "$git_state"
  printf "  %-14s  %s\n"     "Last commit" "$git_last"
  echo ""

  # ── Project stats ───────────────────────────────────────────
  if [[ -f "$LOCAL_STATS" ]]; then
    local sessions tokens_saved last_s
    sessions=$(json_get "$LOCAL_STATS" "sessions")
    tokens_saved=$(json_get "$LOCAL_STATS" "tokens_saved")
    last_s=$(json_get "$LOCAL_STATS" "last_session" | cut -c1-10)

    echo -e "  ${BOLD}This project${RESET}"
    printf "  %s\n" "$(printf '─%.0s' {1..46})"
    printf "  %-14s  %s\n" "Sessions"     "$sessions"
    if [[ "$tokens_saved" -gt 0 ]]; then
      printf "  %-14s  ~%s tokens total\n" "Saved" "$(fmt_tokens $tokens_saved)"
    else
      printf "  %-14s  %s\n" "Saved" "none yet — run: ato focus"
    fi
    printf "  %-14s  %s\n" "Last session" "${last_s:-none}"
    echo ""
  fi
}

cmd_scope() {
  local pattern="${1:-*.ts}"
  header "Token estimate: $pattern"
  local total=0
  while IFS= read -r file; do
    local lines tokens
    lines=$(wc -l < "$file" 2>/dev/null || echo 0)
    tokens=$(( lines * TOKENS_PER_LINE ))
    total=$(( total + tokens ))
    printf "  %-52s %5s tokens\n" "$file" "$(fmt_tokens $tokens)"
  done < <(find . -name "$pattern" \
    -not -path "*/node_modules/*" -not -path "*/.git/*" \
    -not -path "*/dist/*" -not -path "*/build/*" \
    -not -path "*/.next/*" 2>/dev/null | sort)
  echo ""
  echo -e "  ${BOLD}Total: ~$(fmt_tokens $total) tokens${RESET}"
  [[ $total -gt 20000 ]] && warn "Too large for one session — use ato focus"
}

cmd_trim() {
  header "CONTEXT.md — Token Budget"
  [[ ! -f "$CONTEXT_FILE" ]] && { error "No CONTEXT.md found"; exit 1; }

  local total_lines total_tokens issues=0
  total_lines=$(wc -l < "$CONTEXT_FILE" | tr -d ' ')
  total_tokens=$(( total_lines * TOKENS_PER_LINE ))

  # ── Per-section breakdown ──────────────────────────────────────────
  echo ""
  printf "  %-30s %5s  %6s  %s\n" "Section" "Lines" "Tokens" "Share"
  echo "  ──────────────────────────────────────────────────────────"

  local section_name="" section_lines=0
  local warned_sections=()

  _flush_section() {
    [[ -z "$section_name" ]] && return
    local tok=$(( section_lines * TOKENS_PER_LINE ))
    local pct=0
    [[ $total_tokens -gt 0 ]] && pct=$(( tok * 100 / total_tokens ))
    local flag=""
    if [[ $pct -ge 30 ]]; then flag="${YELLOW}← trim${RESET}"; warned_sections+=("$section_name ($pct%)"); fi
    printf "  %-30s %5d  %6s  %3d%%  %b\n" \
      "$section_name" "$section_lines" "~$(fmt_tokens $tok)" "$pct" "$flag"
  }

  while IFS= read -r line; do
    if [[ "$line" =~ ^##[[:space:]] ]]; then
      _flush_section
      section_name="${line#\#\# }"
      section_lines=0
    else
      (( section_lines++ )) || true
    fi
  done < "$CONTEXT_FILE"
  _flush_section

  echo "  ──────────────────────────────────────────────────────────"
  printf "  %-30s %5d  %6s\n" "Total" "$total_lines" "~$(fmt_tokens $total_tokens)"
  echo ""

  # ── Overall health ─────────────────────────────────────────────────
  if [[ $total_lines -gt 200 ]]; then
    warn "$total_lines lines — over target (<200). Run trim."
    (( issues++ )) || true
  else
    success "$total_lines lines — within target (<200) ✓"
  fi

  for s in "${warned_sections[@]+"${warned_sections[@]}"}"; do
    warn "Large section: $s — consider summarizing"
    (( issues++ )) || true
  done

  grep -q "TODO\|FIXME" "$CONTEXT_FILE" && \
    { warn "TODOs/FIXMEs found — move them to TASKS.md"; (( issues++ )) || true; }

  grep -E "^\s{0,4}(export |import |def |class |func )" "$CONTEXT_FILE" 2>/dev/null | grep -q . && \
    { warn "Code found — keep signatures only, remove bodies"; (( issues++ )) || true; }

  echo ""
  [[ $issues -eq 0 ]] && success "CONTEXT.md is lean — no action needed"
  dim "  Target: <200 lines | no full code | no section >30% of total"
  echo ""
}

cmd_prompt() {
  echo ""
  echo -e "${BOLD}  ─────────────────────────────────────────────${RESET}"
  echo -e "${BOLD}  Paste as first message in Claude Code:${RESET}"
  echo -e "${BOLD}  ─────────────────────────────────────────────${RESET}"
  echo ""
  echo "  Read CONTEXT.md fully, then say:"
  echo "  \"Ready. What are we working on today?\""
  echo ""
  echo -e "${BOLD}  ─────────────────────────────────────────────${RESET}"
  echo ""
  dim "  (Claude Code with CLAUDE.md does this automatically on startup)"
}

cmd_reset_stats() {
  local scope="${1:-local}"
  if [[ "$scope" == "global" ]]; then
    rm -f "$GLOBAL_STATS"; json_init_global; success "Global stats reset"
  else
    rm -f "$LOCAL_STATS"; json_init_local "$(basename "$PWD")"; success "Local stats reset"
  fi
}

cmd_update() {
  local repo="https://raw.githubusercontent.com/aarjang/ato/main"
  local install_dir
  install_dir="$(dirname "$(command -v ato 2>/dev/null || echo "$HOME/bin/ato")")"
  local bin="$install_dir/ato"
  local templates_dir="$HOME/.ato/templates"

  info "Current version: v$VERSION"
  info "Downloading latest ato..."

  local tmp
  tmp=$(mktemp)
  if curl -fsSL "$repo/bin/ato" -o "$tmp" 2>/dev/null; then
    local new_version
    new_version=$(grep '^VERSION=' "$tmp" 2>/dev/null | head -1 | tr -d '"' | sed 's/VERSION=//' || echo "")
    if [[ "$new_version" == "$VERSION" ]]; then
      rm -f "$tmp"
      success "Already up to date (v$VERSION)"
      return
    fi
    # Only install if remote version is strictly newer (avoid accidental downgrade)
    local cur_major cur_minor cur_patch new_major new_minor new_patch
    IFS='.' read -r cur_major cur_minor cur_patch <<< "$VERSION"
    IFS='.' read -r new_major new_minor new_patch <<< "$new_version"
    if [[ -z "$new_version" ]] || \
       (( new_major < cur_major )) || \
       (( new_major == cur_major && new_minor < cur_minor )) || \
       (( new_major == cur_major && new_minor == cur_minor && new_patch <= cur_patch )); then
      rm -f "$tmp"
      warn "Remote version (v${new_version:-unknown}) is not newer than local (v$VERSION) — skipping"
      return
    fi
    chmod +x "$tmp"
    mv "$tmp" "$bin"
    success "Updated: v$VERSION → v$new_version"
  else
    rm -f "$tmp"
    error "Download failed — check your connection"
    exit 1
  fi

  info "Updating templates..."
  mkdir -p "$templates_dir"
  for file in TASKS.md DECISIONS.md CLAUDE.md; do
    curl -fsSL "$repo/templates/$file" -o "$templates_dir/$file" 2>/dev/null && \
      success "Updated template: $file" || warn "Could not update $file"
  done

  echo ""
  success "ato is up to date. Run: ato help"
}

# ─── Minimal file creator (fallback: no templates dir) ────────────────
_create_minimal() {
  local file="$1" project="$2"
  case "$file" in
    "TASKS.md") cat > "$file" << EOF
# TASKS — $project

| # | Task | Status |
|---|------|--------|

---

## Task details
<!-- ato add "task description" creates these automatically -->
EOF
    ;;
    "DECISIONS.md") cat > "$file" << EOF
# DECISIONS — $project
<!-- Why things are the way they are. -->

### DEC-001 [Title]
- **Date:** $(date +%Y-%m-%d)
- **Decision:** [what was decided]
- **Rationale:** [why]
- **Alternatives rejected:** [what else was considered]
EOF
    ;;
    "CLAUDE.md") cat > "$file" << EOF
# CLAUDE.md — $project
<!-- Claude Code reads this automatically at the start of every session -->

## On startup
1. Read \`CONTEXT.md\` fully — it is the complete map of this project
2. Say exactly: "Ready. What are we working on today?"
3. Wait for the user's answer before doing anything else

## Working rules
- Only read files relevant to what the user asks for
- Do not scan or explore the codebase unprompted
- Ask before reading anything outside the stated scope
- When done: tell the user what changed in one sentence

## Context stays current automatically
A stop-hook runs \`ato sync\` after every session — CONTEXT.md is kept up to date.
You do not need to remind the user to update it.
EOF
    ;;
  esac
}

# ─── MCP ─────────────────────────────────────────────────────────────

_json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

_strip_ansi() {
  sed 's/\x1B\[[0-9;]*[mGKHF]//g; s/\x1B\[[0-9;]*[A-Za-z]//g'
}

_mcp_reply() {
  local id="$1" text="$2"
  local escaped
  escaped=$(_json_escape "$text")
  printf '{"jsonrpc":"2.0","id":%s,"result":{"content":[{"type":"text","text":"%s"}]}}\n' "$id" "$escaped"
}

_mcp_error() {
  local id="$1" msg="$2"
  local escaped
  escaped=$(_json_escape "$msg")
  printf '{"jsonrpc":"2.0","id":%s,"error":{"code":-32601,"message":"%s"}}\n' "$id" "$escaped"
}

_mcp_tools_list() {
  local id="$1"
  # single-line JSON required for newline-delimited JSON-RPC
  printf '{"jsonrpc":"2.0","id":%s,"result":{"tools":[' "$id"
  printf '{"name":"ato_focus","description":"Auto-detect work area from git and generate focused session file","inputSchema":{"type":"object","properties":{}}},'
  printf '{"name":"ato_sync","description":"Sync CONTEXT.md with git state and record token savings","inputSchema":{"type":"object","properties":{}}},'
  printf '{"name":"ato_note","description":"Save a decision to CONTEXT.md — survives compaction","inputSchema":{"type":"object","properties":{"text":{"type":"string","description":"Decision or key fact to save"}},"required":["text"]}},'
  printf '{"name":"ato_status","description":"Show project health and token budget","inputSchema":{"type":"object","properties":{}}},'
  printf '{"name":"ato_doctor","description":"Audit startup token overhead","inputSchema":{"type":"object","properties":{}}},'
  printf '{"name":"ato_checkpoint","description":"Estimate current context usage and get stopping recommendation","inputSchema":{"type":"object","properties":{}}}'
  printf ']}}\n'
}

_mcp_install() {
  local ato_path
  ato_path=$(command -v ato 2>/dev/null || echo "$HOME/bin/ato")
  local settings=".claude/settings.json"

  if [[ ! -f "$settings" ]]; then
    mkdir -p ".claude"
    cat > "$settings" << EOF
{
  "mcpServers": {
    "ato": {
      "command": "$ato_path",
      "args": ["mcp"],
      "type": "stdio"
    }
  }
}
EOF
    success "ato MCP server registered → $settings"
    info "Restart Claude Code to activate"
    info "Claude can now call: ato_focus, ato_sync, ato_note, ato_status, ato_doctor, ato_checkpoint"
    return
  fi

  if grep -q '"ato"' "$settings" 2>/dev/null; then
    success "ato already registered in $settings"
    return
  fi

  # Merge into existing settings.json using awk
  if grep -q '"mcpServers"' "$settings" 2>/dev/null; then
    awk -v path="$ato_path" '
      /"mcpServers"[[:space:]]*:\s*\{/ {
        print
        printf "    \"ato\": {\"command\": \"%s\", \"args\": [\"mcp\"], \"type\": \"stdio\"},\n", path
        next
      }
      { print }
    ' "$settings" > "$settings.tmp" && mv "$settings.tmp" "$settings"
  else
    # No mcpServers key — inject before closing brace
    awk -v path="$ato_path" '
      /^\}[[:space:]]*$/ {
        printf "  ,\"mcpServers\": {\"ato\": {\"command\": \"%s\", \"args\": [\"mcp\"], \"type\": \"stdio\"}}\n", path
      }
      { print }
    ' "$settings" > "$settings.tmp" && mv "$settings.tmp" "$settings"
  fi

  success "ato MCP server registered → $settings"
  info "Restart Claude Code to activate"
}

cmd_mcp() {
  local subcmd="${1:-}"
  [[ "$subcmd" == "install" ]] && { _mcp_install; return; }

  # stdio MCP server — reads one JSON-RPC message per line
  local line id method tool_name
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue

    id=$(printf '%s' "$line" | grep -o '"id":[^,}]*' | head -1 | sed 's/"id"://' | tr -d ' "')
    [[ -z "$id" ]] && id="null"
    method=$(printf '%s' "$line" | grep -o '"method":"[^"]*"' | head -1 | sed 's/"method":"//;s/"//')

    case "$method" in
      initialize)
        printf '{"jsonrpc":"2.0","id":%s,"result":{"protocolVersion":"2024-11-05","capabilities":{"tools":{}},"serverInfo":{"name":"ato","version":"%s"}}}\n' "$id" "$VERSION"
        ;;
      notifications/initialized)
        ;;  # no response for notifications
      tools/list)
        _mcp_tools_list "$id"
        ;;
      tools/call)
        tool_name=$(printf '%s' "$line" | grep -o '"name":"[^"]*"' | head -1 | sed 's/"name":"//;s/"//')
        local out
        case "$tool_name" in
          ato_focus)      out=$(cmd_focus 2>&1 | _strip_ansi) ;;
          ato_sync)       out=$(cmd_sync  2>&1 | _strip_ansi) ;;
          ato_status)     out=$(cmd_status 2>&1 | _strip_ansi) ;;
          ato_doctor)     out=$(cmd_doctor 2>&1 | _strip_ansi) ;;
          ato_checkpoint) out=$(cmd_checkpoint 2>&1 | _strip_ansi) ;;
          ato_note)
            local txt
            txt=$(printf '%s' "$line" | grep -o '"text":"[^"]*"' | head -1 | sed 's/"text":"//;s/"$//')
            if [[ -z "$txt" ]]; then
              _mcp_error "$id" "Missing required argument: text"; continue
            fi
            out=$(cmd_note "$txt" 2>&1 | _strip_ansi)
            ;;
          *) _mcp_error "$id" "Unknown tool: $tool_name"; continue ;;
        esac
        _mcp_reply "$id" "$out"
        ;;
      *) [[ -n "$method" ]] && _mcp_error "$id" "Unknown method: $method" ;;
    esac
  done
}

# ─── Note ────────────────────────────────────────────────────────────
cmd_note() {
  local note="${1:-}"
  [[ -z "$note" ]] && { error "Usage: ato note \"decision or key fact\""; exit 1; }
  [[ ! -f "$CONTEXT_FILE" ]] && { error "CONTEXT.md not found — run: ato init"; exit 1; }

  local today
  today=$(date +%Y-%m-%d\ %H:%M)

  # Append to existing Session Notes section, or create it
  if grep -q "^## Session Notes" "$CONTEXT_FILE" 2>/dev/null; then
    # Insert note after the ## Session Notes heading
    awk -v note="- [$today] $note" '
      /^## Session Notes/ { print; print note; next }
      { print }
    ' "$CONTEXT_FILE" > "$CONTEXT_FILE.tmp" && mv "$CONTEXT_FILE.tmp" "$CONTEXT_FILE"
  else
    printf '\n## Session Notes\n- [%s] %s\n' "$today" "$note" >> "$CONTEXT_FILE"
  fi

  success "Note saved to CONTEXT.md (survives compaction)"
  dim "  $note"
}

# ─── Slim ────────────────────────────────────────────────────────────
cmd_slim() {
  local target_file="${1:-$CLAUDE_FILE}"
  [[ ! -f "$target_file" ]] && { error "$target_file not found"; exit 1; }

  local lines
  lines=$(wc -l < "$target_file")

  if [[ $lines -le 200 ]]; then
    success "$target_file is already lean ($lines lines) — nothing to do"
    return
  fi

  header "ato slim — $target_file ($lines lines → target: 200)"
  echo ""

  # Parse sections and their sizes
  local section_name="" section_start=1 section_lines=0
  local -a sections=()

  while IFS= read -r line; do
    local linenum="${line%%	*}"  # line number from nl
    local content="${line#*	}"
    if [[ "$content" =~ ^##[[:space:]] ]]; then
      if [[ -n "$section_name" ]]; then
        sections+=("$section_lines|$section_start|$section_name")
      fi
      section_name="$content"
      section_start=$linenum
      section_lines=0
    else
      section_lines=$(( section_lines + 1 ))
    fi
  done < <(nl -ba -nrz -w1 "$target_file" 2>/dev/null | sed 's/^\([0-9]*\)[[:space:]]*/\1\t/')
  [[ -n "$section_name" ]] && sections+=("$section_lines|$section_start|$section_name")

  echo -e "  ${BOLD}Sections by size (largest first):${RESET}"
  printf "  %s\n" "$(printf '─%.0s' {1..48})"

  local IFS_SAVE="$IFS"
  # Sort by size descending and display
  for entry in $(printf '%s\n' "${sections[@]+"${sections[@]}"}" | sort -t'|' -k1 -rn); do
    local sz="${entry%%|*}"
    local rest="${entry#*|}"
    local name="${rest#*|}"
    local tokens=$(( sz * TOKENS_PER_LINE ))
    if [[ $sz -gt 30 ]]; then
      printf "  ${YELLOW}%-40s %3d lines  ~%s tokens${RESET}\n" "$name" "$sz" "$(fmt_tokens $tokens)"
    else
      printf "  %-40s %3d lines  ~%s tokens\n" "$name" "$sz" "$(fmt_tokens $tokens)"
    fi
  done
  IFS="$IFS_SAVE"

  echo ""
  local over=$(( lines - 200 ))
  warn "Need to remove ~$over lines to reach 200-line target"
  echo ""
  info "Options:"
  dim "  1. Manually edit $target_file — remove large sections shown above"
  dim "  2. Move verbose rules to .claude/rules/ (path-scoped, load only when needed)"
  dim "  3. Replace multi-line examples with one-line pointers"
  echo ""
  info "Backup first: cp $target_file ${target_file}.bak"
  echo ""
}

# ─── Doctor ──────────────────────────────────────────────────────────
cmd_doctor() {
  local WINDOW=200000
  local RESERVED=33000   # autocompact buffer — hardcoded by Claude Code, non-negotiable
  local startup_tokens=0
  local issues=0

  echo ""
  printf "${BOLD}╔%50s╗${RESET}\n" | tr ' ' '═'
  printf "${BOLD}║${RESET}  %-48s${BOLD}║${RESET}\n" "ATO Doctor — Startup Token Audit"
  printf "${BOLD}╚%50s╝${RESET}\n" | tr ' ' '═'
  echo ""

  echo -e "  ${BOLD}Startup file overhead${RESET}"
  printf "  %s\n" "$(printf '─%.0s' {1..48})"

  # CONTEXT.md
  if [[ -f "$CONTEXT_FILE" ]]; then
    local ctx_lines ctx_tokens ctx_tag
    ctx_lines=$(wc -l < "$CONTEXT_FILE")
    ctx_tokens=$(( ctx_lines * TOKENS_PER_LINE ))
    startup_tokens=$(( startup_tokens + ctx_tokens ))
    if [[ $ctx_lines -gt 200 ]]; then
      ctx_tag="${YELLOW}⚠ over limit — run: ato trim${RESET}"
      issues=$(( issues + 1 ))
    else
      ctx_tag="${GREEN}lean ✓${RESET}"
    fi
    printf "  %-20s %4d lines  ~%-6s tokens  " "CONTEXT.md" "$ctx_lines" "$(fmt_tokens $ctx_tokens)"
    echo -e "$ctx_tag"
  else
    printf "  %-20s %s\n" "CONTEXT.md" "missing — run: ato init"
    issues=$(( issues + 1 ))
  fi

  # CLAUDE.md
  if [[ -f "$CLAUDE_FILE" ]]; then
    local cl_lines cl_tokens cl_tag
    cl_lines=$(wc -l < "$CLAUDE_FILE")
    cl_tokens=$(( cl_lines * TOKENS_PER_LINE ))
    startup_tokens=$(( startup_tokens + cl_tokens ))
    if [[ $cl_lines -gt 200 ]]; then
      cl_tag="${YELLOW}⚠ Anthropic target: <200 lines — trim this file${RESET}"
      issues=$(( issues + 1 ))
    else
      cl_tag="${GREEN}lean ✓${RESET}"
    fi
    printf "  %-20s %4d lines  ~%-6s tokens  " "CLAUDE.md" "$cl_lines" "$(fmt_tokens $cl_tokens)"
    echo -e "$cl_tag"
  else
    printf "  ${YELLOW}!${RESET}  %-18s %s\n" "CLAUDE.md" "missing"
  fi

  # .claude/memory/ files
  local mem_dir=".claude/memory"
  if [[ -d "$mem_dir" ]]; then
    local mem_files mem_lines mem_tokens
    mem_files=$(find "$mem_dir" -type f 2>/dev/null | wc -l | tr -d ' ')
    mem_lines=$(find "$mem_dir" -type f 2>/dev/null | xargs wc -l 2>/dev/null | tail -1 | awk '{print $1}')
    mem_tokens=$(( ${mem_lines:-0} * TOKENS_PER_LINE ))
    startup_tokens=$(( startup_tokens + mem_tokens ))
    local mem_tag
    if [[ ${mem_tokens:-0} -gt 5000 ]]; then
      mem_tag="${YELLOW}⚠ large — review and prune${RESET}"
      issues=$(( issues + 1 ))
    else
      mem_tag="${GREEN}ok ✓${RESET}"
    fi
    printf "  %-20s %4d files  ~%-6s tokens  " ".claude/memory/" "$mem_files" "$(fmt_tokens $mem_tokens)"
    echo -e "$mem_tag"
  else
    printf "  ${DIM}%-20s not found${RESET}\n" ".claude/memory/"
  fi

  echo ""
  echo -e "  ${BOLD}Token budget${RESET}"
  printf "  %s\n" "$(printf '─%.0s' {1..48})"

  local available=$(( WINDOW - RESERVED - startup_tokens ))
  local used_pct=$(( (RESERVED + startup_tokens) * 100 / WINDOW ))
  local avail_pct=$(( available * 100 / WINDOW ))

  printf "  %-26s  ~%s\n"  "Window (Claude Code)"     "$(fmt_tokens $WINDOW) tokens"
  printf "  %-26s  ~%s\n"  "Reserved buffer (fixed)"  "$(fmt_tokens $RESERVED) tokens"
  printf "  %-26s  ~%s\n"  "Startup files (yours)"    "$(fmt_tokens $startup_tokens) tokens"
  printf "  %s\n" "$(printf '─%.0s' {1..48})"
  if [[ $available -gt 100000 ]]; then
    printf "  ${GREEN}%-26s  ~%s (${avail_pct}%% of window)${RESET}\n" "Available for work" "$(fmt_tokens $available) tokens"
  elif [[ $available -gt 60000 ]]; then
    printf "  ${YELLOW}%-26s  ~%s (${avail_pct}%% of window)${RESET}\n" "Available for work" "$(fmt_tokens $available) tokens"
  else
    printf "  ${RED}%-26s  ~%s (${avail_pct}%% of window)${RESET}\n" "Available for work" "$(fmt_tokens $available) tokens"
  fi
  echo ""

  if [[ $issues -eq 0 ]]; then
    success "All clear — startup overhead is lean"
  else
    warn "$issues issue(s) found — fix them to reclaim tokens before Claude reads a single file"
  fi
  echo ""
}

# ─── Checkpoint ──────────────────────────────────────────────────────
cmd_checkpoint() {
  local WINDOW=200000
  local RESERVED=33000
  local startup_tokens avg_turn_tokens=800 est_turns=20

  # Startup overhead (same as doctor)
  local ctx_lines=0 cl_lines=0 mem_lines=0
  [[ -f "$CONTEXT_FILE" ]] && ctx_lines=$(wc -l < "$CONTEXT_FILE")
  [[ -f "$CLAUDE_FILE"  ]] && cl_lines=$(wc -l < "$CLAUDE_FILE")
  if [[ -d ".claude/memory" ]]; then
    mem_lines=$(find ".claude/memory" -type f 2>/dev/null | \
      xargs wc -l 2>/dev/null | tail -1 | awk '{print $1}') || mem_lines=0
  fi
  startup_tokens=$(( (ctx_lines + cl_lines + ${mem_lines:-0}) * TOKENS_PER_LINE ))

  # Focus file size (what Claude is actively reading this session)
  local focus_tokens=0
  if [[ -f ".ato_focus_auto.md" ]]; then
    local fl
    fl=$(wc -l < ".ato_focus_auto.md")
    focus_tokens=$(( fl * TOKENS_PER_LINE ))
  else
    # Fall back to any cms_focus file
    local cf
    cf=$(find . -maxdepth 1 -name ".cms_focus_*.md" 2>/dev/null | head -1 || true)
    if [[ -n "$cf" ]]; then
      local fl2
      fl2=$(wc -l < "$cf")
      focus_tokens=$(( fl2 * TOKENS_PER_LINE ))
    fi
  fi

  # Session age estimate → rough turn count
  local last_s turns_est
  last_s=$(json_get "$LOCAL_STATS" "last_session" 2>/dev/null | cut -c1-10 || echo "")
  local today
  today=$(date +%Y-%m-%d)
  if [[ "$last_s" == "$today" ]]; then
    turns_est=$avg_turn_tokens   # active session today
  else
    turns_est=$(( avg_turn_tokens / 2 ))   # older session, be conservative
  fi

  local conversation_est=$(( est_turns * turns_est ))
  local total_est=$(( RESERVED + startup_tokens + focus_tokens + conversation_est ))
  [[ $total_est -gt $WINDOW ]] && total_est=$WINDOW

  local used_pct=$(( total_est * 100 / WINDOW ))
  local bar_len=30
  local filled=$(( bar_len * used_pct / 100 ))
  [[ $filled -gt $bar_len ]] && filled=$bar_len

  echo ""
  echo -e "  ${BOLD}Context Checkpoint${RESET}"
  printf "  %s\n" "$(printf '─%.0s' {1..48})"

  printf "  %-26s  ~%s\n" "Reserved buffer"      "$(fmt_tokens $RESERVED)"
  printf "  %-26s  ~%s\n" "Startup files"        "$(fmt_tokens $startup_tokens)"
  printf "  %-26s  ~%s\n" "Focus file"           "$(fmt_tokens $focus_tokens)"
  printf "  %-26s  ~%s\n" "Conversation (est.)"  "$(fmt_tokens $conversation_est)"
  printf "  %s\n" "$(printf '─%.0s' {1..48})"
  printf "  %-26s  ~%s / ~%s  (%d%%)\n" "Estimated used" \
    "$(fmt_tokens $total_est)" "$(fmt_tokens $WINDOW)" "$used_pct"
  echo ""

  # Bar
  local bar filled_s empty_s
  filled_s=$(printf '█%.0s' $(seq 1 $filled 2>/dev/null) || printf '%0.s█' $(seq 1 $filled))
  local empty=$(( bar_len - filled ))
  empty_s=$(printf '░%.0s' $(seq 1 $empty 2>/dev/null) || printf '%0.s░' $(seq 1 $empty))

  if [[ $used_pct -lt 60 ]]; then
    printf "  ${GREEN}%s%s${RESET}  %d%%\n" "$filled_s" "$empty_s" "$used_pct"
    echo ""
    success "Safe to continue — plenty of context remaining"
  elif [[ $used_pct -lt 75 ]]; then
    printf "  ${YELLOW}%s%s${RESET}  %d%%\n" "$filled_s" "$empty_s" "$used_pct"
    echo ""
    warn "Wrap up soon — approaching the quality cliff"
    dim "  Research shows sessions stopping at 75% produce better code than those at 90%"
  else
    printf "  ${RED}%s%s${RESET}  %d%%\n" "$filled_s" "$empty_s" "$used_pct"
    echo ""
    warn "Stop now — context degradation likely already happening"
    dim "  Save your work, run: ato sync, then start a fresh session"
    dim "  Research shows sessions stopping at 75% produce better code than those at 90%"
  fi
  echo ""
  dim "  Note: conversation estimate is approximate (${est_turns} turns × ~${avg_turn_tokens} tokens/turn)"
  dim "  For exact usage: type /context inside Claude Code"
  echo ""
}

# ─── Help ────────────────────────────────────────────────────────────
cmd_help() {
  echo ""
  echo -e "${BOLD}ato v${VERSION}${RESET} — AI Token Optimizer for Claude Code"
  echo -e "${DIM}Reduce token usage 70-90% per session. No task system. Just context.${RESET}"
  echo ""
  echo -e "${BOLD}WORKFLOW${RESET}"
  echo ""
  echo -e "  ${CYAN}1.${RESET}  ato init          Scan project → generate CONTEXT.md + CLAUDE.md"
  echo -e "  ${CYAN}2.${RESET}  claude            Enter Claude Code — it reads CONTEXT.md and asks"
  echo -e "                    \"What are we working on today?\""
  echo -e "  ${CYAN}3.${RESET}  Work freely       No tasks. No scope. Just talk to Claude."
  echo -e "  ${CYAN}4.${RESET}  Session ends      Stop-hook runs ato sync → CONTEXT.md updated"
  echo ""
  echo -e "${BOLD}COMMANDS${RESET}"
  echo "  init [name]          Scan project → generate CONTEXT.md + CLAUDE.md"
  echo "  sync                 Refresh CONTEXT.md (branch, changed files, git log)"
  echo "  status               Project health, token budget, git state, stats"
  echo "  stats [local|global] Token savings breakdown"
  echo "  scope <pattern>      Estimate token cost of a file set (e.g. '*.ts')"
  echo "  trim                 Audit CONTEXT.md for bloat (target: <200 lines)"
  echo "  slim [file]          Show CLAUDE.md sections by size + how to reduce"
  echo "  doctor               Audit startup token overhead (CLAUDE.md, memory, CONTEXT.md)"
  echo "  checkpoint           Estimate current context usage + stopping recommendation"
  echo "  prompt               Print the optimal Claude Code session starter"
  echo "  update               Update ato + templates to latest version"
  echo "  reset-stats [global] Reset stats counters"
  echo "  mcp                  Start ato as an MCP server (stdio)"
  echo "  mcp install          Register ato MCP server in .claude/settings.json"
  echo "  help                 Show this help"
  echo ""
  echo -e "${BOLD}ALSO AVAILABLE (optional task tracking)${RESET}"
  echo "  add \"task\"           Add a task to TASKS.md"
  echo "  focus [number]       Start a scoped session for a specific task"
  echo "  focus --budget 40k   Trim file scope to fit within token budget"
  echo "  note \"text\"          Save a decision to CONTEXT.md (survives compaction)"
  echo "  done <number>        Mark task done + archive"
  echo ""
  echo -e "${BOLD}AUTO-SYNC${RESET}"
  echo "  ato init installs a Claude Code stop-hook → ato sync runs after every"
  echo "  session automatically. CONTEXT.md always reflects the latest state."
  echo ""
}

# ─── Router ──────────────────────────────────────────────────────────
main() {
  local cmd="${1:-help}"; shift || true
  case "$cmd" in
    init)           cmd_init "$@" ;;
    sync)           cmd_sync ;;
    add)            cmd_add "$@" ;;
    focus)          cmd_focus "$@" ;;
    done)           cmd_done "$@" ;;
    stats)          cmd_stats "$@" ;;
    status)         cmd_status "$@" ;;
    scope)          cmd_scope "$@" ;;
    trim)           cmd_trim "$@" ;;
    slim)           cmd_slim "$@" ;;
    note)           cmd_note "$@" ;;
    doctor)         cmd_doctor ;;
    checkpoint)     cmd_checkpoint ;;
    prompt)         cmd_prompt ;;
    update)         cmd_update ;;
    reset-stats)    cmd_reset_stats "$@" ;;
    mcp)            cmd_mcp "$@" ;;
    help|-h|--help) cmd_help ;;
    *)
      error "Unknown command: $cmd"
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
