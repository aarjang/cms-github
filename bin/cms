#!/usr/bin/env bash
# cms → ato migration shim
# cms has been renamed to 'ato' (AI Token Optimizer)

set -euo pipefail

BOLD='\033[1m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'; YELLOW='\033[1;33m'; RESET='\033[0m'

echo ""
echo -e "${YELLOW}!${RESET} ${BOLD}cms has been renamed to 'ato' (AI Token Optimizer)${RESET}"
echo ""

INSTALL_DIR="$(dirname "$0")"
ATO_BIN="$INSTALL_DIR/ato"

if [[ ! -f "$ATO_BIN" ]]; then
  echo -e "${CYAN}→${RESET} Installing ato..."
  if curl -fsSL "https://raw.githubusercontent.com/aarjang/ato/main/bin/ato" -o "$ATO_BIN" 2>/dev/null; then
    chmod +x "$ATO_BIN"
    echo -e "${GREEN}✓${RESET} ato installed at $ATO_BIN"
  else
    echo "  Could not download ato. Install manually:"
    echo "  curl -fsSL https://raw.githubusercontent.com/aarjang/ato/main/install.sh | bash"
    exit 1
  fi
fi

echo -e "${GREEN}✓${RESET} Running: ato $*"
echo ""
exec "$ATO_BIN" "$@"
